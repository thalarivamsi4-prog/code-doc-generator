<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Technical Library | CodeDocGen</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body>
    <nav class="nav">
        <a href="/" class="nav-brand"><i class="fa-solid fa-bolt"></i> CodeDocGen</a>
        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/dashboard">Library</a>
            <a href="/upload">Upload</a>
            <a href="/logout" class="text-secondary small ms-3">Logout</a>
        </div>
    </nav>

    <div class="container mt-5">
        <div class="glass-card">
            <h1>Technical Library</h1>
            <p class="subtitle">Access your multi-project technical documentation vault and global analytics.</p>

            <div class="row g-4 mb-5 text-center">
                <div class="col-md-4">
                    <div
                        style="padding: 2rem; background: rgba(0,0,0,0.02); border-radius: 2rem; border: 1px solid var(--card-border);">
                        <h2 class="fw-bold mb-0">
                            <%= projects.length %>
                        </h2>
                        <label class="text-secondary small text-uppercase fw-bold">Projects</label>
                    </div>
                </div>
                <div class="col-md-4">
                    <div
                        style="padding: 2rem; background: rgba(0,0,0,0.02); border-radius: 2rem; border: 1px solid var(--card-border);">
                        <h2 class="fw-bold mb-0">
                            <%= projects.reduce((acc, p)=> acc + p.fileCount, 0) %>
                        </h2>
                        <label class="text-secondary small text-uppercase fw-bold">Analyzed Files</label>
                    </div>
                </div>
                <div class="col-md-4">
                    <div
                        style="padding: 2rem; background: rgba(0,0,0,0.02); border-radius: 2rem; border: 1px solid var(--card-border);">
                        <h2 class="fw-bold mb-0">
                            <%= projects.reduce((acc, p)=> acc + p.totalLines, 0).toLocaleString() %>
                        </h2>
                        <label class="text-secondary small text-uppercase fw-bold">Global Lines</label>
                    </div>
                </div>
            </div>

            <div id="analyticsSection"
                style="background: #fff; padding: 2rem; border-radius: 2rem; border: 1px solid var(--card-border);">
                <h6 class="fw-bold mb-4">Complexity Distribution</h6>
                <canvas id="complexityChart" height="100"></canvas>
            </div>
        </div>

        <h3 class="fw-bold mb-4 px-3"><i class="fa-solid fa-folder-tree text-primary me-2"></i> Active Projects</h3>

        <div class="dash-grid">
            <% projects.forEach(project=> { %>
                <div class="doc-item">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <span class="lang-tag" style="background: var(--primary-glow); color: var(--primary);">
                            <%= project.lang %>
                        </span>
                        <small class="text-muted">
                            <%= project.timestamp.split(',')[0] %>
                        </small>
                    </div>
                    <h5 class="fw-bold text-truncate mb-2">
                        <%= project.name %>
                    </h5>
                    <p class="text-secondary small mb-4">Total Assets: <strong>
                            <%= project.fileCount %>
                        </strong> | Complexity: <strong>
                            <%= project.totalLines.toLocaleString() %> LOC
                        </strong></p>

                    <div class="d-flex gap-2">
                        <a href="/project/<%= project.id %>" class="btn btn-primary flex-grow-1 py-2">Open Project
                            Hub</a>
                        <a href="/delete-project/<%= project.id %>" class="btn btn-outline-danger px-3"
                            onclick="return confirm('Archive this entire project?')">
                            <i class="fa-solid fa-trash-can"></i>
                        </a>
                    </div>
                </div>
                <% }) %>

                    <% if (projects.length===0) { %>
                        <div class="col-12 text-center py-5 glass-card" style="border: 2px dashed #94a3b8;">
                            <i class="fa-solid fa-box-open mb-3" style="font-size: 4rem; color: #cbd5e1;"></i>
                            <h5 class="text-muted">Your vault is currently empty.</h5>
                            <a href="/upload" class="btn btn-primary mt-3">Upload your first project</a>
                        </div>
                        <% } %>
        </div>
    </div>

    <footer>
        <p>Verified Technical Library &copy; 2026 CodeDocGen</p>
    </footer>

    <script>
        const projectData = <% - JSON.stringify(projects.slice(0, 10)) %>;
        if (projectData.length > 0) {
            new Chart(document.getElementById('complexityChart'), {
                type: 'line',
                data: {
                    labels: projectData.map(p => p.name.substring(0, 15)),
                    datasets: [{
                        label: 'Lines of Code',
                        data: projectData.map(p => p.totalLines),
                        borderColor: '#d97706',
                        backgroundColor: 'rgba(217, 119, 6, 0.05)',
                        fill: true, tension: 0.4
                    }]
                },
                options: { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } }
            });
        } else {
            document.getElementById('analyticsSection').style.display = 'none';
        }
    </script>
</body>

</html>