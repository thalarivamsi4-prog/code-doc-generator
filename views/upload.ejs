<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Upload | CodeDocGen</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <nav class="nav">
        <a href="/" class="nav-brand"><i class="fa-solid fa-bolt"></i> CodeDocGen</a>
        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/dashboard">Library</a>
            <a href="/upload">Upload</a>
            <a href="/admin">Analytics</a>
        </div>
    </nav>

    <div class="container">
        <div class="glass-card text-center">
            <h1>Technical Intake</h1>
            <p class="subtitle">Securely bridge your local source files with our automated analysis engine. Supports
                multi-file and ZIP project ingestion.</p>

            <form action="/upload" method="POST" enctype="multipart/form-data"
                style="max-width: 800px; margin: 0 auto;">
                <div class="form-group">
                    <label for="codefile" class="upload-area" id="drop-zone"
                        style="border: 2px dashed #cbd5e1; border-radius: 2rem; padding: 4rem 2rem; cursor: pointer; transition: all 0.3s; display: block;">
                        <i class="fa-solid fa-cloud-arrow-up mb-4" style="font-size: 3rem; color: var(--primary);"></i>
                        <h4 class="fw-bold">Local File Intake</h4>
                        <p class="text-muted small">Select code or .ZIP projects</p>
                        <input type="file" name="codefile" id="codefile" multiple required
                            onchange="updateFileName(this)" style="display: none;">
                    </label>
                    <div id="file-name" class="mt-3 text-center fw-bold text-primary" style="min-height: 1.5rem;"></div>
                </div>
                <button type="submit" class="btn btn-primary px-5 py-3 w-100"
                    style="border-radius: 1.5rem; font-size: 1.1rem;">
                    Analyze Local Files
                </button>
            </form>

            <div class="my-5 d-flex align-items-center justify-content-center gap-3" style="opacity: 0.5;">
                <div style="height: 1px; background: #94a3b8; flex: 1;"></div>
                <span class="text-muted small fw-bold">OR</span>
                <div style="height: 1px; background: #94a3b8; flex: 1;"></div>
            </div>

            <form action="/upload-github" method="POST" style="max-width: 800px; margin: 0 auto;">
                <div class="p-4 rounded-4" style="background: rgba(0,0,0,0.02); border: 1px solid var(--primary-glow);">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <i class="fa-brands fa-github" style="font-size: 2rem; color: #0f172a;"></i>
                        <h5 class="fw-bold mb-0">Remote Repo Ingestion</h5>
                    </div>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0" style="border-radius: 1rem 0 0 1rem;">
                            <i class="fa-solid fa-link text-muted"></i>
                        </span>
                        <input type="url" name="githubUrl" class="form-control border-start-0 py-3"
                            placeholder="https://github.com/user/repo" required style="border-radius: 0 1rem 1rem 0;">
                    </div>
                </div>
                <button type="submit" class="btn btn-secondary px-5 py-3 w-100 mt-4"
                    style="border-radius: 1.5rem; font-size: 1.1rem;">
                    Import from GitHub <i class="fa-solid fa-wand-sparkles ms-2"></i>
                </button>
            </form>
        </div>
    </div>

    <script>
        function updateFileName(input) {
            const files = input.files;
            const display = document.getElementById('file-name');
            const dropZone = document.getElementById('drop-zone');
            if (files.length === 0) return;

            display.innerHTML = files.length === 1
                ? '<i class="fa-solid fa-file"></i> Ready: ' + files[0].name
                : '<i class="fa-solid fa-box-archive"></i> Batch Ready: ' + files.length + ' assets selected';

            dropZone.style.borderColor = 'var(--primary)';
            dropZone.style.background = 'rgba(217, 119, 6, 0.02)';
        }
    </script>
</body>

</html>