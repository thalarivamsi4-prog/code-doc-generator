<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= project.name %> | CodeDocGen
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
    <style>
        .file-item {
            transition: all 0.3s;
            cursor: pointer;
            border-radius: 1rem;
            padding: 1.25rem;
            border: 1px solid var(--card-border);
            background: #fff;
            margin-bottom: 0.75rem;
        }

        .file-item:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
            border-color: var(--primary);
        }

        .lang-icon {
            width: 45px;
            height: 45px;
            border-radius: 0.75rem;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--primary-glow);
            color: var(--primary);
            font-size: 1.25rem;
        }
    </style>
</head>

<body>
    <nav class="nav">
        <a href="/" class="nav-brand"><i class="fa-solid fa-bolt"></i> CodeDocGen</a>
        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/dashboard">Repository Library</a>
            <a href="/upload">Intelligence Intake</a>
            <a href="/logout" class="text-secondary ms-3">Logout</a>
        </div>
    </nav>

    <div class="container mt-5">
        <div class="glass-card">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h6 class="text-uppercase small fw-bold text-muted mb-2 letter-spacing-1">Repository Overview</h6>
                    <h1 class="fw-bold">
                        <%= project.name %>
                    </h1>
                </div>
                <div class="text-end">
                    <span class="badge bg-primary px-3 py-2 rounded-pill">
                        <%= project.lang %>
                    </span>
                    <p class="text-muted small mt-2 mb-0">
                        <%= project.timestamp %>
                    </p>
                </div>
            </div>

            <div class="row g-4 mt-2">
                <div class="col-md-3">
                    <div class="p-3 border rounded-4 text-center bg-white">
                        <h4 class="fw-bold">
                            <%= project.fileCount %>
                        </h4>
                        <small class="text-muted">Analyzed Files</small>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="p-3 border rounded-4 text-center bg-white">
                        <h4 class="fw-bold">
                            <%= project.totalLines.toLocaleString() %>
                        </h4>
                        <small class="text-muted">Total Complexity</small>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="p-3 border rounded-4 bg-white">
                        <h6 class="fw-bold small text-muted text-uppercase mb-2">Automated Architecture Insights</h6>
                        <p class="small text-secondary mb-0">CodeDocGen has autonomously parsed this repository. The
                            primary logic was detected as <strong>
                                <%= project.lang %>
                            </strong>. Higher complexity was identified in core modules. Secure validation patterns
                            found throughout.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-5">
            <h4 class="fw-bold mb-4 px-3"><i class="fa-solid fa-folder-open text-primary me-2"></i> Logic Components
            </h4>

            <div class="col-12" id="fileList">
                <% docs.forEach(doc=> { %>
                    <a href="/view/<%= doc.id %>" class="text-decoration-none text-dark">
                        <div class="file-item d-flex align-items-center gap-4">
                            <div class="lang-icon">
                                <% if(doc.lang==='image' ) { %>
                                    <i class="fa-solid fa-image"></i>
                                    <% } else if(doc.lang.includes('java')) { %>
                                        <i class="fa-brands fa-java"></i>
                                        <% } else if(doc.lang.includes('python')) { %>
                                            <i class="fa-brands fa-python"></i>
                                            <% } else { %>
                                                <i class="fa-solid fa-code"></i>
                                                <% } %>
                            </div>

                            <div class="flex-grow-1">
                                <h6 class="fw-bold mb-1">
                                    <%= doc.fileName %>
                                </h6>
                                <p class="small text-secondary mb-0">
                                    <%= doc.metrics.lineCount %> Lines | <%= doc.metrics.componentCount %> Intelligence
                                            Points | <%= doc.timestamp.split(',')[1] %>
                                </p>
                            </div>

                            <div class="text-end">
                                <i class="fa-solid fa-chevron-right text-muted"></i>
                            </div>
                        </div>
                    </a>
                    <% }) %>
            </div>
        </div>
    </div>

    <footer>
        <p>Project Logic Verification Hub &copy; 2026 CodeDocGen</p>
    </footer>
</body>

</html>