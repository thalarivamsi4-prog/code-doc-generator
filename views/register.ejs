<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Join | CodeDocGen</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <nav class="nav">
        <a href="/" class="nav-brand"><i class="fa-solid fa-bolt"></i> CodeDocGen</a>
        <div class="nav-links">
            <a href="/login" class="btn btn-secondary">Login</a>
        </div>
    </nav>

    <div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
        <div class="glass-card" style="width: 100%; max-width: 450px; padding: 3rem;">
            <h2 class="fw-bold mb-2 text-center">New Intelligence</h2>
            <p class="text-secondary text-center mb-4">Start documenting your projects like a pro.</p>

            <% if (error) { %>
                <div class="alert alert-danger py-2 small" style="border-radius: 1rem;">
                    <%= error %>
                </div>
                <% } %>

                    <form action="/register" method="POST">
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Username</label>
                            <input type="text" name="username" class="form-control py-2" required
                                style="border-radius: 0.75rem;">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Email</label>
                            <input type="email" name="email" class="form-control py-2" required
                                style="border-radius: 0.75rem;">
                        </div>
                        <div class="mb-4">
                            <label class="form-label small fw-bold">Password</label>
                            <input type="password" name="password" class="form-control py-2" required
                                style="border-radius: 0.75rem;">
                        </div>
                        <button type="submit" class="btn btn-primary w-100 py-2" style="border-radius: 1rem;">
                            Join CodeDocGen <i class="fa-solid fa-user-plus ms-2"></i>
                        </button>
                    </form>

                    <p class="mt-4 text-center text-secondary small">
                        Already part of the team? <a href="/login"
                            class="text-primary fw-bold text-decoration-none">Sign In</a>
                    </p>
        </div>
    </div>
</body>

</html>