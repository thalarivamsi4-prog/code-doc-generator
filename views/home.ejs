<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CodeDocGen | AI-Powered Logic Analysis</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <nav class="nav">
        <a href="/" class="nav-brand"><i class="fa-solid fa-bolt"></i> CodeDocGen</a>
        <div class="nav-links">
            <% if (user) { %>
                <a href="/dashboard">Library</a>
                <a href="/logout" class="btn btn-secondary py-1 px-3">Logout</a>
                <% } else { %>
                    <a href="/login">Login</a>
                    <a href="/register" class="btn btn-primary py-1 px-3">Join Free</a>
                    <% } %>
        </div>
    </nav>

    <div class="container text-center" style="padding-top: 5vh;">
        <div class="glass-card animate">
            <span class="badge mb-4"
                style="background: var(--primary-glow); color: var(--primary); padding: 0.6rem 1.2rem; border-radius: 2rem; font-weight: 700; letter-spacing: 1px;">
                <i class="fa-solid fa-wand-magic-sparkles"></i> POWERED BY HEURISTIC AI
            </span>
            <h1>The Professional Way <br><span style="color: var(--primary);">to Document Code.</span></h1>
            <p class="subtitle mt-3">Upload your source files or full ZIP projects. Our AI engine analyzes logic
                patterns, detects components, and generates enterprise-grade documentation instantly.</p>

            <div class="mt-5 d-flex gap-3 justify-content-center">
                <% if (user) { %>
                    <a href="/upload" class="btn btn-primary px-5 py-3 shadow-lg"
                        style="border-radius: 1.5rem; font-size: 1.1rem;">
                        <i class="fa-solid fa-cloud-arrow-up"></i> Go to Upload
                    </a>
                    <% } else { %>
                        <a href="/register" class="btn btn-primary px-5 py-3 shadow-lg"
                            style="border-radius: 1.5rem; font-size: 1.1rem;">
                            Get Started Free
                        </a>
                        <% } %>
                            <a href="/dashboard" class="btn btn-secondary px-5 py-3"
                                style="border-radius: 1.5rem; font-size: 1.1rem;">
                                Browse Library
                            </a>
            </div>
        </div>

        <div class="row g-4 mt-2">
            <div class="col-md-4">
                <div class="glass-card" style="padding: 2.5rem; margin-bottom: 0;">
                    <i class="fa-solid fa-microchip mb-3 text-primary" style="font-size: 2.5rem;"></i>
                    <h5 class="fw-bold">Smart Analysis</h5>
                    <p class="text-secondary small">Automatically identifies functions, classes, and logic intent using
                        heuristic AI.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="glass-card" style="padding: 2.5rem; margin-bottom: 0;">
                    <i class="fa-solid fa-file-pdf mb-3 text-warning" style="font-size: 2.5rem;"></i>
                    <h5 class="fw-bold">Expert Exports</h5>
                    <p class="text-secondary small">Generate high-fidelity PDF reports ready for client handovers or
                        internal audits.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="glass-card" style="padding: 2.5rem; margin-bottom: 0;">
                    <i class="fa-solid fa-box-archive mb-3 text-success" style="font-size: 2.5rem;"></i>
                    <h5 class="fw-bold">Full Project ZIP</h5>
                    <p class="text-secondary small">Upload entire repositories. We unpack and document every source file
                        inside.</p>
                </div>
            </div>
        </div>
    </div>

    <footer>
        <p>Built for Developers, by Developers &copy; 2026 CodeDocGen</p>
    </footer>
</body>

</html>