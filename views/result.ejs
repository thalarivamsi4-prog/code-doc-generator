<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Intelligence Report: <%= result.fileName %> | CodeDocGen</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <link rel="stylesheet" href="/style.css">
    <style>
        .intel-summary {
            background: #fff;
            border-radius: 2rem;
            padding: 2.5rem;
            border: 1px solid var(--card-border);
            position: relative;
            overflow: hidden;
        }

        .intel-summary::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 6px;
            height: 100%;
            background: var(--primary);
        }

        .ai-badge {
            background: var(--primary-glow);
            color: var(--primary);
            padding: 0.5rem 1rem;
            border-radius: 2rem;
            font-size: 0.7rem;
            font-weight: 800;
            text-transform: uppercase;
        }

        code {
            font-family: 'JetBrains Mono', monospace !important;
            font-size: 0.9rem !important;
        }

        pre {
            background: #282c34 !important;
            padding: 1.5rem !important;
            border-radius: 0 0 1.5rem 1.5rem;
            margin: 0 !important;
        }
    </style>
</head>

<body>
    <nav class="nav">
        <a href="/" class="nav-brand"><i class="fa-solid fa-brain"></i> CodeDocGen Pro</a>
        <div class="nav-links">
            <a href="/dashboard">Library</a>
            <a href="/upload">Intelligence Intake</a>
            <a href="/logout" class="ms-4 text-secondary small">Logout</a>
        </div>
    </nav>

    <div class="container py-5">
        <div class="row g-5">
            <div class="col-lg-7">
                <!-- STRONG UPGRADE 3: EXECUTIVE FILE SUMMARY -->
                <div class="intel-summary mb-5">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <span class="ai-badge"><i class="fa-solid fa-sparkles"></i> AI Executive Summary</span>
                        <h2 class="fw-bold mb-0">
                            <%= result.fileName %>
                        </h2>
                    </div>
                    <p class="text-secondary line-height-relaxed mb-0">
                        This module has been identified as a <strong>
                            <%= result.lang %>
                        </strong> component.
                        Its primary role in your architecture is <strong>Logical Encapsulation</strong>.
                        We detected <strong>
                            <%= result.metrics.componentCount %> intelligence points
                        </strong>.
                        Pro-Tip: Files of this scale (<strong>
                            <%= result.metrics.lineCount %> lines
                        </strong>) are ideal for maintenance; they are focused, modular, and easy to unit test.
                    </p>
                </div>

                <h4 class="fw-bold mb-4 px-3"><i class="fa-solid fa-chalkboard-user text-primary me-2"></i> Logic
                    Deep-Dive</h4>
                <div class="row g-3">
                    <% result.functions.forEach(f=> { %>
                        <div class="col-12">
                            <div class="glass-card" style="padding: 1.5rem;">
                                <div class="d-flex align-items-center gap-3 mb-2">
                                    <div
                                        style="background: var(--primary-glow); color: var(--primary); width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                                        <i class="fa-solid fa-code-commit"></i>
                                    </div>
                                    <h6 class="fw-bold mb-0">
                                        <%= f.name %>
                                    </h6>
                                    <span class="ms-auto text-muted small">Line <%= f.line %></span>
                                </div>
                                <p class="text-secondary small mb-0">
                                    <%= f.explanation %>
                                </p>
                            </div>
                        </div>
                        <% }) %>
                </div>
            </div>

            <!-- Visual Code Viewer -->
            <div class="col-lg-5">
                <h4 class="fw-bold mb-4"><i class="fa-solid fa-terminal text-primary"></i> The Source Core</h4>
                <div class="editor-shell" style="border-radius: 1.5rem; overflow: hidden; border: 1px solid #3e4451;">
                    <div class="editor-header d-flex align-items-center justify-content-between"
                        style="background: #21252b; padding: 1rem 1.5rem;">
                        <div class="d-flex gap-2">
                            <div style="width: 12px; height: 12px; border-radius: 50%; background: #ff5f56;"></div>
                            <div style="width: 12px; height: 12px; border-radius: 50%; background: #ffbd2e;"></div>
                            <div style="width: 12px; height: 12px; border-radius: 50%; background: #27c93f;"></div>
                        </div>
                        <span class="badge bg-dark text-muted font-monospace small">
                            <%= result.lang %>
                        </span>
                    </div>
                    <pre><code class="language-<%= result.lang %>"><%= code %></code></pre>
                </div>

                <div class="mt-4">
                    <a href="/download-pdf/<%= result.id %>" class="btn btn-secondary w-100 py-3"
                        style="border-radius: 1.5rem;">
                        <i class="fa-solid fa-download me-2"></i> Download Technical Specs
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script>hljs.highlightAll();</script>
</body>

</html>