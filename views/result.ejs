<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Source Analysis: <%= result.fileName %> | CodeDocGen</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <!-- VS CODE SYNTAX THEME (Atom One Dark) -->
    <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>

    <link rel="stylesheet" href="/style.css">
    <style>
        code {
            font-family: 'JetBrains Mono', 'Cascadia Code', 'Fira Code', monospace !important;
            font-size: 0.95rem !important;
            line-height: 1.6;
            background: transparent !important;
        }

        pre {
            background: #282c34 !important;
            /* Atom One Dark Primary BG */
            padding: 1.5rem !important;
            border-radius: 0 0 1.5rem 1.5rem;
            margin: 0 !important;
        }

        .editor-shell {
            border: 1px solid #3e4451;
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.3);
            border-radius: 1.5rem;
            overflow: hidden;
        }

        .editor-header {
            background: #21252b;
            padding: 1rem 1.5rem;
            border-bottom: 1px solid #181a1f;
        }
    </style>
</head>

<body>
    <nav class="nav">
        <a href="/" class="nav-brand"><i class="fa-solid fa-bolt"></i> CodeDocGen</a>
        <div class="nav-links">
            <a href="/dashboard">Back to Library</a>
            <a href="/logout" class="text-secondary ms-3">Logout</a>
        </div>
    </nav>

    <div class="container-fluid py-5">
        <div class="container">
            <div class="row g-5">
                <!-- Metadata & AI Analysis -->
                <div class="col-lg-7">
                    <div class="glass-card mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">
                                <%= result.lang %>
                            </span>
                            <small class="text-muted">
                                <%= result.timestamp %>
                            </small>
                        </div>
                        <h1 class="fw-bold">
                            <%= result.fileName %>
                        </h1>
                        <p class="text-secondary mb-0">Analyzed by CodeDocGen Behavioral Engine. Detected <strong>
                                <%= result.metrics.componentCount %> logic units
                            </strong> across <strong>
                                <%= result.metrics.lineCount %> lines
                            </strong>.</p>
                    </div>

                    <h4 class="fw-bold mb-4 px-3"><i class="fa-solid fa-wand-sparkles text-primary me-2"></i> Behavioral
                        Intelligence</h4>
                    <div class="row g-3">
                        <% result.functions.forEach(f=> { %>
                            <div class="col-12">
                                <div class="glass-card" style="padding: 1.5rem;">
                                    <div class="d-flex align-items-center gap-3 mb-2">
                                        <div
                                            style="background: var(--primary-glow); color: var(--primary); width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 0.8rem;">
                                            <i class="fa-solid fa-microchip"></i>
                                        </div>
                                        <h6 class="fw-bold mb-0 text-primary">Unit: <%= f.name %>
                                        </h6>
                                        <small class="ms-auto badge bg-light text-muted">Line <%= f.line %></small>
                                    </div>
                                    <p class="text-secondary small mb-0">
                                        <%= f.explanation %>
                                    </p>
                                </div>
                            </div>
                            <% }) %>

                                <% if (result.functions.length===0) { %>
                                    <div class="col-12 glass-card p-5 text-center">
                                        <i class="fa-solid fa-code-merge mb-3 opacity-25" style="font-size: 3rem;"></i>
                                        <p class="text-muted">General script module. No isolated function patterns
                                            detected.</p>
                                    </div>
                                    <% } %>
                    </div>
                </div>

                <!-- Source Inspector (The Visual Hub) -->
                <div class="col-lg-5">
                    <h4 class="fw-bold mb-4"><i class="fa-solid fa-terminal text-primary"></i> Source Inspector</h4>

                    <% if (result.lang==='image' ) { %>
                        <div class="glass-card p-2 text-center" style="overflow: hidden;">
                            <img src="<%= result.rawCode %>" alt="Technical Asset" class="img-fluid rounded-4 shadow-sm"
                                style="max-height: 800px; object-fit: contain;">
                            <p class="mt-3 text-secondary small">Visual Intelligence Preview</p>
                        </div>
                        <% } else { %>
                            <div class="editor-shell">
                                <div class="editor-header d-flex align-items-center">
                                    <div class="d-flex gap-2">
                                        <div class="dot red"
                                            style="width: 12px; height: 12px; border-radius: 50%; background: #ff5f56;">
                                        </div>
                                        <div class="dot yellow"
                                            style="width: 12px; height: 12px; border-radius: 50%; background: #ffbd2e;">
                                        </div>
                                        <div class="dot green"
                                            style="width: 12px; height: 12px; border-radius: 50%; background: #27c93f;">
                                        </div>
                                    </div>
                                    <span class="ms-3 small text-muted font-monospace">
                                        <%= result.fileName %>
                                    </span>
                                </div>
                                <pre><code class="language-<%= result.lang %>"><%= code %></code></pre>
                            </div>
                            <% } %>

                                <div class="mt-4">
                                    <a href="/download-pdf/<%= result.id %>" class="btn btn-secondary w-100 py-3"
                                        style="border-radius: 1.5rem;">
                                        <i class="fa-solid fa-file-pdf me-2"></i> Export Master PDF Report
                                    </a>
                                </div>
                </div>
            </div>
        </div>
    </div>

    <footer>
        <p>Project Logic Verification Hub &copy; 2026 CodeDocGen</p>
    </footer>

    <script>hljs.highlightAll();</script>
</body>

</html>