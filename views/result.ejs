<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Mentor Intel: <%= result.fileName %> | CodeDocGen</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <link rel="stylesheet" href="/style.css">
    <style>
        .ai-intel-card {
            background: linear-gradient(135deg, #1e293b, #0f172a);
            color: #f8fafc;
            border-radius: 2rem;
            padding: 2.5rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .ai-text {
            line-height: 1.8;
            font-size: 1rem;
            color: #cbd5e1;
            white-space: pre-wrap;
        }

        .glow-text {
            color: #fbbf24;
            text-shadow: 0 0 10px rgba(251, 191, 36, 0.3);
        }
    </style>
</head>

<body>
    <nav class="nav">
        <a href="/" class="nav-brand"><i class="fa-solid fa-brain"></i> CodeDocGen <span
                class="badge bg-warning text-dark ms-2">AI ADVANCED</span></a>
        <div class="nav-links">
            <a href="/dashboard">My Library</a>
            <a href="/upload">Intelligence Intake</a>
            <a href="/logout" class="ms-3 text-secondary small">Logout</a>
        </div>
    </nav>

    <div class="container py-5">
        <div class="row g-5">
            <div class="col-lg-7">
                <!-- AI SUPER-BRAIN EXPLANATION -->
                <div class="ai-intel-card mb-5">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="bg-warning text-dark rounded-circle d-flex align-items-center justify-content-center"
                            style="width: 45px; height: 45px; font-size: 1.2rem;">
                            <i class="fa-solid fa-bolt"></i>
                        </div>
                        <h2 class="fw-bold mb-0 glow-text">OpenAI Deep Analysis</h2>
                    </div>
                    <div class="ai-text">
                        <%= result.aiExplanation
                            || "The AI is warming up its neural networks. Please ensure your API key is correctly set in the .env file."
                            %>
                    </div>
                </div>

                <h4 class="fw-bold mb-4 px-3 text-secondary"><i class="fa-solid fa-microchip me-2"></i> Logic Anatomy
                </h4>
                <div class="row g-3">
                    <% result.functions.forEach(f=> { %>
                        <div class="col-12">
                            <div class="glass-card p-4">
                                <div class="d-flex align-items-center gap-3 mb-2">
                                    <div class="text-primary"><i class="fa-solid fa-code-branch"></i></div>
                                    <h6 class="fw-bold mb-0">Module: <%= f.name %>
                                    </h6>
                                    <span class="ms-auto text-muted small">DNA Index: <%= f.line %></span>
                                </div>
                                <p class="text-secondary small mb-0">
                                    <%= f.explanation %>
                                </p>
                            </div>
                        </div>
                        <% }) %>
                </div>
            </div>

            <!-- SOURCE VIEWER -->
            <div class="col-lg-5">
                <div class="sticky-top" style="top: 100px;">
                    <h4 class="fw-bold mb-4 text-secondary"><i class="fa-solid fa-terminal me-2"></i> Source Core</h4>
                    <div class="editor-shell"
                        style="border-radius: 1.5rem; overflow: hidden; border: 1px solid #334155;">
                        <div class="editor-header" style="background: #1e293b; padding: 1rem 1.5rem;">
                            <div class="d-flex gap-2">
                                <div style="width: 10px; height: 10px; border-radius: 50%; background: #ef4444;"></div>
                                <div style="width: 10px; height: 10px; border-radius: 50%; background: #f59e0b;"></div>
                                <div style="width: 10px; height: 10px; border-radius: 50%; background: #10b981;"></div>
                            </div>
                        </div>
                        <pre><code class="language-<%= result.lang.toLowerCase() %>"><%= code %></code></pre>
                    </div>

                    <div class="mt-4 d-grid gap-2">
                        <button class="btn btn-warning py-3 fw-bold" style="border-radius: 1rem;"
                            onclick="window.print()">
                            <i class="fa-solid fa-print me-2"></i> Print Engineering Report
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>hljs.highlightAll();</script>
</body>

</html>