<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Analysis Result | CodeDocGen</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
    <!-- Code Highlighting -->
    <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.7.0/styles/atom-one-dark.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.7.0/highlight.min.js"></script>
    <script>hljs.highlightAll();</script>
</head>

<body>
    <nav class="nav">
        <a href="/" class="nav-brand"><i class="fa-solid fa-bolt"></i> CodeDocGen</a>
        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/dashboard">Library</a>
            <a href="/upload">Upload</a>
            <a href="/admin">Analytics</a>
        </div>
    </nav>

    <div class="container">
        <div class="glass-card">
            <div class="d-flex justify-content-between align-items-start mb-5 border-bottom pb-4">
                <div>
                    <h2 class="fw-bold mb-1">Technical Analytics</h2>
                    <p class="text-secondary"><i class="fa-solid fa-file-code"></i> Report for <%= result.fileName %>
                    </p>
                </div>
                <div class="d-flex gap-2">
                    <a href="/download-pdf/<%= result.id %>" class="btn btn-primary shadow-sm">
                        <i class="fa-solid fa-file-pdf"></i> PDF
                    </a>
                    <a href="/download/<%= result.id %>" class="btn btn-secondary">
                        <i class="fa-solid fa-download"></i> MD
                    </a>
                </div>
            </div>

            <div class="row g-4 mb-5">
                <div class="col-md-6 text-center">
                    <div
                        style="background: rgba(217,119,6,0.05); padding: 2rem; border-radius: 2rem; border: 1px solid var(--primary-glow);">
                        <h1 class="mb-0" style="font-size: 3rem;">
                            <%= result.metrics.lineCount %>
                        </h1>
                        <p class="text-secondary fw-bold text-uppercase small">Total Line Complexity</p>
                    </div>
                </div>
                <div class="col-md-6 text-center">
                    <div
                        style="background: rgba(22,163,74,0.05); padding: 2rem; border-radius: 2rem; border: 1px solid rgba(22,163,74,0.1);">
                        <h1 class="mb-0" style="font-size: 3rem;">
                            <%= result.metrics.componentCount %>
                        </h1>
                        <p class="text-secondary fw-bold text-uppercase small">Detected Logic Units</p>
                    </div>
                </div>
            </div>

            <div class="row g-5">
                <div class="col-lg-7">
                    <h4 class="fw-bold mb-4"><i class="fa-solid fa-layer-group text-primary"></i> Behavioral Analysis
                    </h4>
                    <% if (result.functions.length> 0) { %>
                        <% result.functions.forEach(f=> { %>
                            <div class="mb-4 p-4 border rounded-4 bg-white shadow-sm"
                                style="border-left: 6px solid var(--primary) !important;">
                                <div class="d-flex justify-content-between mb-2 align-items-center">
                                    <h6 class="fw-bold mb-0 text-primary"><i class="fa-solid fa-cube me-2"></i>
                                        <%= f.name %>
                                    </h6>
                                    <span class="badge rounded-pill bg-light text-dark border">Line <%= f.line %></span>
                                </div>
                                <p class="text-secondary small mb-0">
                                    <%= f.explanation %>
                                </p>
                            </div>
                            <% }) %>
                                <% } else { %>
                                    <div class="text-center py-5 bg-light rounded-4 border border-dashed">
                                        <p class="text-muted">Extracted components not found.</p>
                                    </div>
                                    <% } %>
                </div>
                <div class="col-lg-5">
                    <h4 class="fw-bold mb-4"><i class="fa-solid fa-terminal text-primary"></i> Source Inspector</h4>
                    <% if (result.lang==='image' ) { %>
                        <div class="glass-card p-2 text-center" style="overflow: hidden;">
                            <img src="<%= result.rawCode %>" alt="Technical Asset" class="img-fluid rounded-4 shadow-sm"
                                style="max-height: 600px; object-fit: contain;">
                            <p class="mt-3 text-secondary small">Visual Technical Asset Preview</p>
                        </div>
                        <% } else { %>
                            <div class="editor-shell">
                                <div class="editor-header">
                                    <div class="dot red"></div>
                                    <div class="dot yellow"></div>
                                    <div class="dot green"></div>
                                    <span class="ms-2 small text-muted">
                                        <%= result.fileName %>
                                    </span>
                                </div>
                                <pre><code class="language-<%= result.lang %>"><%= code %></code></pre>
                            </div>
                            <% } %>
                </div>
            </div>
        </div>
    </div>

    <footer>
        <p>Verified Technical Report &copy; 2026 CodeDocGen</p>
    </footer>
</body>

</html>