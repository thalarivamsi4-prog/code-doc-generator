<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Global Intelligence Dashboard | CodeDocGen</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body>
    <nav class="nav">
        <a href="/" class="nav-brand"><i class="fa-solid fa-gauge-high"></i> CodeDocGen Control</a>
        <div class="nav-links">
            <a href="/dashboard">Return to Library</a>
            <a href="/logout" class="ms-3 text-secondary">Logout</a>
        </div>
    </nav>

    <div class="container mt-5">
        <div class="glass-card mb-5">
            <h6 class="text-uppercase small fw-bold text-muted mb-2">System Analytics</h6>
            <h1 class="fw-bold">Global Intelligence Dashboard</h1>
            <p class="text-secondary">Monitoring the health and activity of the CodeDocGen AI Documentation Ecosystem.
            </p>

            <div class="row g-4 mt-4">
                <div class="col-md-4">
                    <div class="p-4 border rounded-4 text-center bg-white shadow-sm">
                        <i class="fa-solid fa-users text-primary mb-3" style="font-size: 2rem;"></i>
                        <h2 class="fw-bold mb-0">
                            <%= stats.totalUsers %>
                        </h2>
                        <label class="text-muted small">Registered Users</label>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-4 border rounded-4 text-center bg-white shadow-sm">
                        <i class="fa-solid fa-folder-tree text-warning mb-3" style="font-size: 2rem;"></i>
                        <h2 class="fw-bold mb-0">
                            <%= stats.totalProjects %>
                        </h2>
                        <label class="text-muted small">Total Projects</label>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-4 border rounded-4 text-center bg-white shadow-sm">
                        <i class="fa-solid fa-file-shield text-success mb-3" style="font-size: 2rem;"></i>
                        <h2 class="fw-bold mb-0">
                            <%= stats.totalDocs %>
                        </h2>
                        <label class="text-muted small">AI Analyzed Files</label>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-8">
                <div class="glass-card">
                    <h5 class="fw-bold mb-4">System Capacity Output</h5>
                    <canvas id="systemChart" height="150"></canvas>
                </div>
            </div>
            <div class="col-md-4">
                <div class="glass-card">
                    <h5 class="fw-bold mb-4">Security Overview</h5>
                    <ul class="list-group list-group-flush small">
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            AI Neural Link
                            <span class="badge bg-success rounded-pill">Active</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            Database Health
                            <span class="badge bg-success rounded-pill">Optimized</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            Session Scoping
                            <span class="badge bg-primary rounded-pill">Enforced</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <footer>
        <p>System Intelligence Terminal &copy; 2026 CodeDocGen</p>
    </footer>

    <script>
        const ctx = document.getElementById('systemChart');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['Users', 'Projects', 'Analyses'],
                datasets: [{
                    label: 'System Load',
                    data: [<%= stats.totalUsers %>, <%= stats.totalProjects %>, <%= stats.totalDocs %>],
                    backgroundColor: ['#d97706', '#fbbf24', '#0f172a'],
                    borderRadius: 10
                }]
            },
            options: { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } }
        });
    </script>
</body>

</html>